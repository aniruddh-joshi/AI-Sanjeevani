{
    "name": "sanjeevani-ai-monorepo",
    "version": "1.0.0",
    "description": "AI-Powered Healthcare Receptionist",
    "private": true,
    "scripts": {
        "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
        "dev": "npx concurrently \"cd backend && node server.js\" \"cd frontend && npm run dev\"",
        "build": "cd frontend && npm install && npm run build && cd ../backend && npm install"
    },
    "dependencies": {
        "@google/genai": "^1.44.0",
        "@google/generative-ai": "^0.24.1",
        "@supabase/supabase-js": "^2.98.0",
        "body-parser": "^2.2.2",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "express-rate-limit": "^8.3.0",
        "helmet": "^8.1.0",
        "jsonwebtoken": "^9.0.3",
        "node-cron": "^4.2.1",
        "nodemailer": "^8.0.1",
        "serverless-http": "^3.2.0",
        "telegraf": "^4.16.3"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}
